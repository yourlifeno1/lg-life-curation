name: Daily Naver Trend Update

on:
  schedule:
    # 매일 한국 시간 오전 2시 (UTC 17시)에 실행
    - cron: '0 17 * * *'
  workflow_dispatch: # 수동으로도 실행 가능하게 버튼 생성

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v3

    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.9'

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install requests pandas

    - name: Run Trend Crawler
      run: python trend_crawler.py # 크롤러 파일명이 다르면 수정해주세요
